{
  "name": "webext-theme-engine",
  "version": "0.1.0",
  "description": "Dynamic theme engine for Chrome extensions — CSS variables, presets, custom themes, dark/light mode, and user-configurable color schemes.",
  "author": "Zovo <hello@zovo.one>",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "theme",
    "dark-mode",
    "css-variables",
    "color-scheme",
    "manifest-v3",
    "browser-extension",
    "customization",
    "styling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-theme-engine.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --environment happy-dom",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "happy-dom": "^20.8.3",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
